# x-rag Environment Configuration Template
# Copy this file to .env and fill in your values

# ========================================
# Server Configuration
# ========================================
DEBUG=false
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# ========================================
# Embedding Configuration
# ========================================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_SIZE=1000

# ========================================
# Vector Store Configuration
# ========================================
VECTOR_STORE_PERSIST_DIR=./data/chroma
VECTOR_STORE_COLLECTION_NAME=documents
VECTOR_STORE_DISTANCE=cosine

# ========================================
# Text Splitter Configuration
# ========================================
TEXT_SPLITTER_PROVIDER=langchain  # langchain | llamaindex
TEXT_SPLITTER_STRATEGY=recursive  # recursive | character | token | semantic（langchain）/ sentence | token | semantic | markdown（llamaindex）
TEXT_SPLITTER_CHUNK_SIZE=512
TEXT_SPLITTER_CHUNK_OVERLAP=50

# ========================================
# Retrieval Configuration
# ========================================
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.7
RETRIEVAL_USE_MMR=false
RETRIEVAL_MMR_LAMBDA=0.5

# ========================================
# Generation Configuration
# ========================================
GENERATION_PROVIDER=deepseek
GENERATION_MODEL=deepseek-chat
GENERATION_TEMPERATURE=0.7
GENERATION_MAX_TOKENS=2000
GENERATION_TIMEOUT=30

# ========================================
# LLM Provider API Configuration
# ========================================
# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat

# 豆包 API (字节跳动)
DOUBAO_API_KEY=your-doubao-api-key-here
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_NAME=doubao-pro-32k

# 阿里云百炼 API (通义千问)
ALIYUN_API_KEY=your-aliyun-api-key-here
ALIYUN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_MODEL_NAME=qwen-plus

# 小米 Mimo API
MIMO_API_KEY=your-mimo-api-key-here
MIMO_API_BASE=https://api.xiaomi.com
MIMO_MODEL_NAME=mimo-v2.5-pro

# ========================================
# Rate Limit Configuration
# ========================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ========================================
# CORS Configuration
# ========================================
CORS_ENABLED=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080
