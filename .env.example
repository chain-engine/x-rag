# ====================================
# 模型 API 配置
# ====================================

# DeepSeek Model Configuration
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# DEEPSEEK_MODEL_NAME=deepseek-chat

# Doubao Model Configuration
# DOUBAO_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL_NAME=ep-xxxxxxxxxxxxxx

# Alibaba Cloud Tongyi Qianwen Model Configuration
# ALIYUN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ALIYUN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# ALIYUN_MODEL_NAME=qwen-plus

# ====================================
# 外部服务 API 配置
# ====================================

# 高德地图 API 配置（天气查询）
# AMAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith 配置
# LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx_xxxxxxxxxxxxx
# LANGSMITH_API_BASE=https://api.langsmith.com/v1
# LANGSMITH_MODEL_NAME=langsmith-chat

# ====================================
# 数据库配置 (用于 TextToSQL)
# ====================================

# 数据库连接配置
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=your_database

# 或者使用完整的数据库 URL（优先级高于分项配置）
# DB_URL=mysql+pymysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ====================================
# 通用配置
# ====================================

# LLM 温度参数 (0.0-2.0, 越高越随机)
TEMPERATURE=0.0

# 调试模式
DEBUG=False

# 结构化输出模式
STRUCTURED=False

# Default provider used by TextToSQL tools. Defaults to MODEL_NAME when empty.
# TEXT_TO_SQL_MODEL_NAME=deepseek

# TextToSQL query safety limits
TEXT_TO_SQL_MAX_ROWS=100
TEXT_TO_SQL_QUERY_TIMEOUT=30

# ====================================
# MCP 服务器配置
# ====================================

# 天气 MCP 服务器
# WEATHER_MCP_BASE_URL=http://localhost:8000
# WEATHER_MCP_PATH=/mcp
# WEATHER_MCP_MODE=http

# 秋池 MCP 服务器
# QIUCHI_MCP_BASE_URL=http://localhost:8000
# QIUCHI_MCP_PATH=/mcp
# QIUCHI_MCP_MODE=http

# MCP tools are disabled by default to avoid probing a local server on startup.
# Set to True after starting/configuring your MCP service.
MCP_ENABLED=False
